{
  "name": "prelog",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "lint": "eslint .",
    "typecheck": "prisma generate && tsc --noEmit",
    "test": "npm run test:unit && npm run test:integration && npm run test:e2e",
    "test:ci": "npm run lint && npm run typecheck && npm run build && npm test",
    "test:unit": "vitest run --config vitest.unit.config.ts",
    "test:integration": "npm run test:db:reset && vitest run --config vitest.integration.config.ts",
    "test:e2e": "npm run test:db:reset && playwright test",
    "test:db:reset": "prisma generate && tsx tests/helpers/reset-test-db.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "prisma db seed",
    "prisma:studio": "prisma studio"
  },
  "dependencies": {
    "@chenglou/pretext": "0.0.7",
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0",
    "bcryptjs": "3.0.3",
    "dotenv": "17.4.2",
    "framer-motion": "12.40.0",
    "lucide-react": "1.17.0",
    "next": "16.2.6",
    "next-auth": "4.24.14",
    "pg": "8.21.0",
    "pinyin-pro": "^3.28.1",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-markdown": "10.1.0",
    "rehype-autolink-headings": "7.1.0",
    "rehype-slug": "6.0.0",
    "remark-gfm": "4.0.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "25.9.1",
    "@types/pg": "8.20.0",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "prisma": "7.8.0",
    "tsx": "4.22.3",
    "typescript": "6.0.3",
    "vitest": "^4.1.7"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
