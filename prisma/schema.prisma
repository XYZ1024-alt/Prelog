generator client {
  provider            = "prisma-client"
  output              = "../src/generated/prisma"
  importFileExtension = "ts"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
}

enum PostStatus {
  DRAFT
  PUBLISHED
}

enum CoverMode {
  GLYPH
  MANUAL
}

enum CommentStatus {
  PENDING
  APPROVED
  HIDDEN
  SPAM
}

enum PostRevisionReason {
  SAVE
  PUBLISH
  RESTORE
}

enum AnalyticsMetricType {
  PAGE_VIEW
  READ_DEPTH
  SEARCH
  SEARCH_ZERO
  REFERRER
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String
  role         Role     @default(ADMIN)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model SiteSettings {
  id                    String   @id
  siteName              String
  siteTagline           String
  heroTitle             String
  heroExcerpt           String
  aboutTitle            String
  aboutIntro            String
  aboutWriting          String
  aboutAudience         String
  aboutTopics           String
  footerPrimary         String
  footerSecondary       String
  friendsEnabled        Boolean  @default(true)
  friendsIntro          String   @default("这里收录了一些值得阅读与长期关注的朋友和站点。")
  friendsRequirements   String   @default("网站可正常访问\n内容以原创为主\n已添加本站友链\n不含违法、侵权或低质量采集内容")
  friendsContactLabel   String   @default("联系站长")
  friendsContactUrl     String   @default("/about")
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model FriendLink {
  id          String   @id @default(cuid())
  name        String
  url         String   @unique
  description String
  logoUrl     String?
  sortOrder   Int      @default(0)
  isVisible   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isVisible, sortOrder, name])
}

model Category {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  posts       Post[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Tag {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  posts     PostTag[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model PostTag {
  postId String
  tagId  String
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postId, tagId])
}

model Post {
  id               String             @id @default(cuid())
  title            String
  slug             String             @unique
  excerpt          String
  content          String
  coverImage       String?
  coverMode        CoverMode          @default(GLYPH)
  glyphRecipe      Json?
  glyphSourceHash  String?
  glyphGeneratedAt DateTime?
  status           PostStatus         @default(DRAFT)
  readingMinutes   Int                @default(1)
  seoTitle         String?
  seoDescription   String?
  categoryId       String?
  category         Category?          @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  tags             PostTag[]
  comments         Comment[]
  revisions        PostRevision[]
  previewTokens    PostPreviewToken[]
  publishedAt      DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  @@index([status, publishedAt])
  @@index([categoryId])
}

model PostRevision {
  id        String             @id @default(cuid())
  postId    String
  post      Post               @relation(fields: [postId], references: [id], onDelete: Cascade)
  snapshot  Json
  reason    PostRevisionReason
  createdAt DateTime           @default(now())

  @@index([postId, createdAt])
}

model PostPreviewToken {
  id        String   @id @default(cuid())
  postId    String   @unique
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([expiresAt])
}

model Comment {
  id             String        @id @default(cuid())
  postId         String
  post           Post          @relation(fields: [postId], references: [id], onDelete: Cascade)
  parentId       String?
  parent         Comment?      @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies        Comment[]     @relation("CommentReplies")
  author         String
  email          String
  body           String
  status         CommentStatus @default(PENDING)
  moderationNote String?
  spamScore      Int           @default(0)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([postId, status, createdAt])
  @@index([parentId])
  @@index([status, createdAt])
}

model RateLimitBucket {
  key       String   @id
  count     Int      @default(1)
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([expiresAt])
}

model AnalyticsDailyMetric {
  date      DateTime
  type      AnalyticsMetricType
  path      String
  dimension String              @default("")
  count     Int                 @default(0)
  updatedAt DateTime            @updatedAt

  @@id([date, type, path, dimension])
  @@index([date])
  @@index([type, date])
  @@index([path, type, date])
}
